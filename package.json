{
    "name": "knoxccl-static",
    "version": "1.0.0",
    "description": "The knoxccl.org website.",
    "private": true,
    "main": "index.js",
    "repository": {
        "type": "git",
        "url": "git@github.com:dwvisser/knoxccl.git"
    },
    "license": "CC-BY-NC-ND-4.0",
    "scripts": {
        "clean": "cd `git rev-parse --show-toplevel` && rm -rf dist",
        "develop": "webpack --mode=development",
        "build": "webpack --mode=production",
        "analyze": "ANALYZE=true webpack --mode=production",
        "serve": "./serve.sh",
        "lint": "eslint src/ --ext .js",
        "lint:fix": "eslint src/ --ext .js --fix",
        "format": "prettier --write src/**/*.{js,scss}",
        "format:check": "prettier --check src/**/*.{js,scss}"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.27",
        "bootstrap-icons": "^1.8.1",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^6.6.0",
        "dotenv-webpack": "^9.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "exports-loader": "^3.1.0",
        "imports-loader": "^3.1.1",
        "node-forge": "^1.4.0",
        "object-path": "^0.11.8",
        "postcss-loader": "^7.2.4",
        "prettier": "^3.8.1",
        "sass": "^1.34.0",
        "sass-loader": "^12.4.0",
        "style-loader": "^3.3.1",
        "webpack": "^5.105.0",
        "webpack-bundle-analyzer": "^5.3.0",
        "webpack-cli": "^4.9.2",
        "workbox-webpack-plugin": "^7.0.0"
    },
    "dependencies": {
        "@popperjs/core": "^2.9.2",
        "bootstrap": "^5.0.1",
        "dark-mode-toggle": "^0.4.11",
        "lazyload": "^2.0.0-rc.2",
        "lite-vimeo-embed": "^0.1.0"
    }
}
